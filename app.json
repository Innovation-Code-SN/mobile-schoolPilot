{
  "expo": {
    "name": "SchoolPilot Mobile",
    "slug": "schoolpilot-mobile",
    "scheme": "schoolpilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D86430"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.schoolpilot.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D86430"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.schoolpilot.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiBaseUrl": "http://45.92.111.211:5053",
      "appName": "SchoolPilot Mobile"
    }
  }
}
